# Gato extension configuration
# Copy to .env and set values. Pi does NOT auto-load .env files —
# source them in your shell or use direnv (.envrc).

# filter-history: number of days of chat history to keep in context (default: 60)
GATO_HISTORY_DAYS=60

# generate-summary: days before regenerating conversation summary (default: 3)
GATO_SUMMARY_STALENESS_DAYS=3
