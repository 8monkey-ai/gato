# Gato configuration
# Copy to .env and set values. Pi does NOT auto-load .env files —
# source them in your shell or use direnv (.envrc).

# pi-context-history: number of days of chat history to keep in context (default: 60)
PI_HISTORY_DAYS=60

# pi-context-history: days before regenerating the conversation summary (default: 3)
PI_COMPACT_STALENESS_DAYS=3

# pi-context-history feature toggles — each is on unless set to "false" or "0"
PI_TRIM_HISTORY=true        # drop messages older than PI_HISTORY_DAYS
PI_STRIP_TOOL_HISTORY=true  # strip prior turns' tool calls/results
PI_COMPACT=true             # rolling summary: regenerate on resume + inject into system prompt
PI_APPEND_MESSAGE=true      # /add-user-message and /add-assistant-message commands
